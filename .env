# Copier ce fichier vers .env à la racine du projet :
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/macOS)

# MySQL (conteneur Docker)
MYSQL_ROOT_PASSWORD=club_root_change_me
MYSQL_DATABASE=clubdb
MYSQL_HOST_PORT=3307

# Connexion Spring Boot → MySQL Docker
MYSQL_USER=root
MYSQL_PASSWORD=club_root_change_me

# Spring Boot
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8084

# JWT (utiliser une valeur longue et aléatoire en production)
JWT_SECRET=clubFootSecretKeyForJWTTokenGenerationSecure2024VeryLongSecret
JWT_EXPIRATION=86400000
